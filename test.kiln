
name := "kiln"
alive := true
missing := nil
count := length(name)
print(name, alive, missing, count)
print(type(name), type(alive), type(missing), type(count), type(print))

text := to_string(count)
print(text, type(text))

number := to_number("42")
decimal := to_number("4.5")
bad := to_number("wat")
print(number, decimal, bad)

decimal = 0xFF
print(decimal)

if alive {
    scoped := "then branch"
    print(scoped)
} else {
    scoped := "else branch"
    print(scoped)
}

first := false
second := true
if first {
    print("first")
} else if second {
    print("second")
} else {
    print("none")
}

print(!alive, !!alive, !missing)

looping := true
for looping {
    print("for cond")
    looping = false
}

if true {
    for {
        print("for infinite")
        break
    }
}

id := function(value) {
    return value
}
print(id("function value"))

print(type(id))

missing_arg := function(a, b) {
    print(a, b)
}
missing_arg(10)

shadow := function(a) {
    if true {
        a := "inner"
        print(a)
    }
    print(a)
}
shadow("outer")

ret_a := 7
ret_b := 9
return ret_a, ret_b
print(ret_a, ret_b)
print("after return")
assert(alive, "alive should be true")
