// Kiln surface test.
// Covers scanner -> parser -> codegen -> VM behavior for the implemented language core.

import "debug"
import "array"
import "foo"

// Basic literal forms.
print("--- literals ---")

print(nil)
print(true)
print(false)
print(0)
print(42)
print(0xFF)
print(3.14)
print(.5)
print("hello")

// Mutable bindings, assignment, and block-local scope.
print("--- bindings and scopes ---")

counter := 10
print(counter)

counter = 20
print(counter)

message := "hi"
print(message)

if true {
    scoped_value := "scoped"
    print(scoped_value)
}

// `global` declares into the shared State global environment.
// The declaration can happen at top level or from inside a function.
print("--- globals ---")

global shared_count := 42
print(shared_count)

shared_count = 99
print(shared_count)

declare_inner_global :: function() {
    global inner_global := "from function"
}
declare_inner_global()
print(inner_global)

global read_shared_count :: function() {
    return shared_count
}
print(read_shared_count())

set_shared_count :: function() {
    shared_count = 77
}
set_shared_count()
print(shared_count)

// File-root declarations live in main_env.
// Functions can read and assign them without closures or upvalues.
// Locals and parameters may shadow outer names; resolution uses the nearest binding.
print("--- main env and shadowing ---")

main_label := "file root"

read_main_label :: function() {
    print(main_label)
}
read_main_label()

main_counter := 1

bump_main_counter :: function() {
    main_counter += 1
}
bump_main_counter()
print(main_counter)

shadow_name := "main binding"

show_local_shadow :: function() {
    shadow_name := "local binding"
    print(shadow_name)
}
show_local_shadow()
print(shadow_name)

show_param_shadow :: function(shadow_name) {
    print(shadow_name)
}
show_param_shadow("parameter binding")
print(shadow_name)

global layered_name := "global binding"
layered_name := "main binding"
print(layered_name)

// Imported native modules are explicit namespaces.
print("--- native modules ---")

print(debug.echo("module echo"))

echo_from_function :: function() {
    print(debug.echo("module in function"))
}
echo_from_function()

module_items := []
array.push(module_items, "first")
array.push(module_items, "second")
print(module_items[0], module_items[1])
print(array.pop(module_items))
print(array.pop(module_items))

// Source modules compile and run during import loading.
// Exported bindings are visible through the namespace; private top-level bindings stay module-local.
print("--- source modules ---")

print(foo.bar(31))
print(foo.counter)
foo.counter = 10
foo.counter += 5
print(foo.counter)

// `::` makes the binding immutable, not the referenced object.
// The array binding is fixed, but its indexed contents can still change.
print("--- immutable bindings ---")

fixed_answer :: 42
print(fixed_answer)

fixed_array :: [1, 2]
fixed_array[0] = 99
print(fixed_array[0])

global fixed_global :: "locked"
print(fixed_global)

// Function literals, calls, shadowing, nil-filled missing args, and statement calls.
print("--- functions ---")

identity :: function(value) {
    return value
}
print(identity("identity"))

do_nothing :: function() {}
print(do_nothing())

show_shadowing :: function(value) {
    if true {
        value := "inner"
        print(value)
    }
    print(value)
}
show_shadowing("outer")

show_missing_args :: function(first, second, third) {
    print(first, second, third)
}
show_missing_args(1)

return_two_values :: function() {
    return 7, 9
}
print(return_two_values())

print("statement call")

// Mutable function bindings can be reassigned.
print("--- function patching ---")

patchable_function := function() {
    print("patch one")
}
patchable_function()

patchable_function = function() {
    print("patch two")
}
patchable_function()

// Conditional blocks and else-if parsing.
print("--- if/else ---")

condition := true
if condition {
    print("if taken")
} else {
    print("if not taken")
}

if false {
    print("first")
} else if true {
    print("else if taken")
} else {
    print("else not taken")
}

// Conditional and unconditional loops both use `break`.
print("--- for/break ---")

for true {
    print("for cond")
    break
}

for {
    print("for infinite")
    break
}

// Subject switch, string equality in cases, subjectless switch, and nested switch.
print("--- switch ---")

status_code := 200
switch status_code {
case 200: print("ok")
case 404: print("not found")
else:     print("unknown")
}

switch "same" {
case "same": print("string text equal")
else:        print("string equality failed")
}

switch {
case true: print("subjectless")
else:      print("not taken")
}

outer_value := 1
inner_value := 2
switch outer_value {
case 1:
    switch inner_value {
    case 2: print("nested switch")
    else:   print("inner else")
    }
else:
    print("outer else")
}

// Unary truthiness and numeric negation.
print("--- unary ---")

print(!false)
print(!true)
print(!nil)
print(!0)
print(!!"nested")

print(-42)
print(-3.14)
print(-0xFF)
number_to_negate := 9
print(-number_to_negate)
print(--number_to_negate)

// Arithmetic and comparison precedence.
print("--- arithmetic and comparison ---")

print(1 + 2 * 3)
print((1 + 2) * 3)
print(10 - 3 - 2)
print(20 / 2 / 2)
print(7 % 3)
print(20 % 6)
print(2 + 7 % 3)
print(-1 + 2)
print(-(1 + 2))
print(1 + 2 * 3 == 7)

print(1 < 2)
print(2 <= 2)
print(3 > 2)
print(3 >= 3)
print(1 == 1.0)
print(1 != 2)

if 1 + 2 * 3 == 7 {
    print("precedence ok")
}

for 1 < 2 {
    print("comparison for")
    break
}

switch 6 {
case 1 + 5: print("comparison switch")
else:       print("comparison switch failed")
}

// String concatenation shares additive precedence and requires explicit conversion.
print("--- string concat ---")

print("kiln" .. "vm")
print("a" .. "b" .. "c")
print("result: " .. to_string(42))
print("a" .. "b" == "ab")

// Logical operators short-circuit and return bool.
print("--- and/or ---")

print(true and true)
print(true and false)
print(false and true)
print(false or true)
print(nil or false)
print(0 and "text")
print(false or 0)
print([] and map{})

global logical_hits := 0
logical_mark :: function() {
    logical_hits += 1
    return true
}

print(false and logical_mark())
print(logical_hits)
print(true or logical_mark())
print(logical_hits)
print(true and logical_mark())
print(logical_hits)
print(false or logical_mark())
print(logical_hits)

print(1 < 2 and 3 < 4)
print(false or 1 + 2 == 3)
print(true or false and false)

// Fallback else is nil-only coalescing.
print("--- fallback else ---")

print(nil else "fallback")
print(false else true)
print(0 else 99)
print("value" else "fallback")
print(nil else nil else "final")

global fallback_hits := 0
fallback_mark :: function() {
    fallback_hits += 1
    return "used"
}

print("kept" else fallback_mark())
print(fallback_hits)
print(nil else fallback_mark())
print(fallback_hits)

print(nil else false or true)
print(false or nil else "x")

// Compound assignment reads the target once, computes, then writes back.
print("--- compound assignment ---")

compound := 10
compound += 5
print(compound)
compound -= 3
print(compound)
compound *= 2
print(compound)
compound /= 4
print(compound)
compound = 10
compound %= 4
print(compound)

shared_count += 1
print(shared_count)

compound_items := [10]
compound_items[0] += 5
print(compound_items[0])

compound_map := map { score: 10 }
compound_map["score"] += 7
print(compound_map["score"])

// Native globals installed by the host standard environment.
print("--- builtins ---")

print("variadic", 1, 2, 3)

print(type(nil))
print(type(true))
print(type(42))
print(type(3.14))
print(type("s"))
print(type(print))

print(length("hello"))

assert(true)
assert(1, "truthy asserts ok")
assert("hi")

print(to_string(42))
print(to_string(true))
print(to_string(nil))

print(to_number("42"))
print(to_number("3.14"))
print(to_number("bad"))

// Multiple result declarations and assignments.
// A direct final call expands; a call before another comma value is single-valued.
print("--- multi value ---")

left_decl, right_decl := 1, 2
print(left_decl, right_decl)

present_value, missing_value := 1
print(present_value, missing_value)

make_pair_a :: function() {
    return 10, 20
}
expanded_a, expanded_b := make_pair_a()
print(expanded_a, expanded_b)

make_pair_b :: function() {
    return 10, 20
}
first_call_result, explicit_value := make_pair_b(), 99
print(first_call_result, explicit_value)

swap_left := 1
swap_right := 2
swap_left, swap_right = swap_right, swap_left
print(swap_left, swap_right)

make_pair_c :: function() {
    return 3, 4
}
assign_left := 1
assign_right := 2
assign_left, assign_right = make_pair_c()
print(assign_left, assign_right)

// Array literals, nested indexing, indexed assignment, and indexed swap.
print("--- arrays ---")

numbers := [10, 20, 30]
print(numbers[0], numbers[1], numbers[2])

numbers[1] = 99
print(numbers[1])

nested_arrays := [[1], [2]]
print(nested_arrays[0][0], nested_arrays[1][0])

swap_array_left := [1]
swap_array_right := [2]
swap_array_left[0], swap_array_right[0] = swap_array_right[0], swap_array_left[0]
print(swap_array_left[0], swap_array_right[0])

// Map literals use static string keys: identifier shorthand or string literals.
// Values are full expressions, so calls are valid as values.
print("--- maps ---")

make_label :: function() {
    return "Kiln VM"
}

settings :: map {
    name: "kiln",
    "display name": make_label(),
    enabled: true,
}

print(settings["name"])
print(settings["display name"])
print(settings["enabled"])

dynamic_key := "name"
print(settings[dynamic_key])

empty_map :: map {}
print(length(empty_map))

settings["enabled"] = false
print(settings["enabled"])

missing_setting := nil
nil_from_binding :: map {
    optional: missing_setting,
}
print(length(nil_from_binding))
print(nil_from_binding["optional"])

// Collections and functions nested together.
// This stresses parser temp slots, chained indexing, and call roots from indexed values.
print("--- collection composition ---")

workspace :: map {
    root: "kilnvm_dev",
    paths: ["src", "dev", "refs"],
    flags: map {
        debug: true,
        verbose: false,
    },
    actions: map {
        echo: function(value) {
            print(value)
        },
        id: function(value) {
            return value
        },
    },
}

print(workspace["root"])
print(workspace["paths"][1])
print(workspace["flags"]["debug"])

workspace["paths"][0] = "source"
workspace["flags"]["verbose"] = true
print(workspace["paths"][0])
print(workspace["flags"]["verbose"])

workspace["actions"]["echo"]("from nested function")
print(workspace["actions"]["id"]("returned from nested function"))

// Map construction from locals and returning indexed map values.
make_record :: function(name, value) {
    return map {
        name: name,
        value: value,
    }
}

record := make_record("answer", 42)
print(record["name"], record["value"])

read_record :: function(input_record) {
    return input_record["name"], input_record["value"]
}

record_name, record_value := read_record(record)
print(record_name, record_value)

// Returning a function and immediately calling it.
make_printer :: function() {
    return function() {
        print("chained call")
    }
}
make_printer()()

// Arrays can store functions and indexed function values can be called or replaced.
callbacks := [
    function() {
        print("first callback")
    },
    function() {
        print("second callback")
    },
]
callbacks[1]()

callbacks[0] = function() {
    print("replaced callback")
}
callbacks[0]()

print((numbers[1]))

// Return forwarding expands only the final call expression in a return list.
print("--- return forwarding ---")

many_values :: function() {
    return 1, 2, 3
}

forward_many :: function(fn) {
    return fn()
}
forward_a, forward_b, forward_c := forward_many(many_values)
print(forward_a, forward_b, forward_c)

prefix_many :: function(fn) {
    return 9, fn()
}
prefix_a, prefix_b, prefix_c, prefix_d := prefix_many(many_values)
print(prefix_a, prefix_b, prefix_c, prefix_d)

left_values :: function() {
    return 7, 8
}

right_values :: function() {
    return 10, 11
}

final_call_only_expands :: function(left_fn, right_fn) {
    return left_fn(), right_fn()
}
return_a, return_b, return_c := final_call_only_expands(left_values, right_values)
print(return_a, return_b, return_c)

no_values :: function() {
    return
}

prefix_empty :: function(fn) {
    return 5, fn()
}
empty_a, empty_b := prefix_empty(no_values)
print(empty_a, empty_b)

indexed_final_call :: function() {
    funcs := [
        function() {
            return 20, 21
        },
    ]
    return 19, funcs[0]()
}
indexed_a, indexed_b, indexed_c := indexed_final_call()
print(indexed_a, indexed_b, indexed_c)

native_final_call :: function() {
    return type(123)
}
print(native_final_call())

// Declaration commits after RHS lowering, so the RHS reads the outer binding.
print("--- delayed commit ---")

shadow_source := 10
if true {
    shadow_source := shadow_source
    print(shadow_source)
}

// Top-level return exits the chunk.
print("--- return ---")
return "done"
print("never reached")
