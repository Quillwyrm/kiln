fn main() {
    n := 50000
    mod := 100000
    rounds := 5
    total := 0
    r := 0

    for r < rounds {
        arr := []int{}
        i := 0

        for i < n {
            arr = append(arr, i % 1000)
            i++
        }

        i = 0
        for i < n {
            arr[i] = (arr[i] + i) % mod
            total = (total + arr[i]) % mod
            i++
        }

        r++
    }

    printf("%d\n", total)
}
