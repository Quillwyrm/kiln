fn main() {
    n := 750000
    mod := 100000
    m := map[str]int{}
    m["a"] = 1
    m["b"] = 2
    m["c"] = 3
    m["d"] = 4
    total := 0
    i := 0

    for i < n {
        m["a"] = (m["a"] + i + m["d"]) % mod
        m["b"] = (m["b"] + m["a"] + 7) % mod
        m["c"] = m["a"] + m["b"]
        if m["c"] > mod {
            m["c"] = m["c"] % mod
        }
        total = (total + m["a"] + m["b"] + m["c"]) % mod
        i++
    }

    printf("%d\n", total + m["a"] + m["b"] + m["c"])
}
