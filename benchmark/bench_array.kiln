import "arrays"

run :: function() {
    n := 50000
    mod := 100000
    rounds := 5
    total := 0
    r := 0

    for r < rounds {
        arr := []
        i := 0

        for i < n {
            arrays.push(arr, i % 1000)
            i += 1
        }

        i = 0
        for i < n {
            arr[i] = (arr[i] + i) % mod
            total = (total + arr[i]) % mod
            i += 1
        }

        r += 1
    }

    print(total)
}

run()
